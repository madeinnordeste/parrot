<!DOCTYPE html>

<html class="light" lang="pt-BR">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />

    <link rel="icon" type="image/x-icon" href="favicon.ico" />
    <title>Parrot - Nightscout data stats</title>
    <meta property="og:title" content="Parrot - Nightscout Data Statistics" />
    <meta property="og:description"
        content="Analyze your Nightscout glucose monitoring data. Track Time in Range (TIR), Mean Glucose, and Ambulatory Glucose Profile (AGP) for better diabetes management." />
    <meta property="og:image" itemprop="image" content="{{ base_url }}/assets/parrot.png" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="{{ base_url }}/" />
    <meta property="og:logo" content="{{ base_url }}/assets/parrot.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Parrot - Nightscout Data Statistics" />
    <meta name="twitter:description"
        content="Analyze your Nightscout glucose monitoring data with Parrot. Monitor key metrics like TIR and AGP for improved health insights." />
    <meta name="twitter:image" content="{{ base_url }}/assets/parrot.png" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-2211CBDEVR"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'G-2211CBDEVR');
    </script>
    <!-- Google Fonts: Plus Jakarta Sans & Public Sans -->
    <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&amp;family=Public+Sans:wght@300;400;500;600;700;800;900&amp;display=swap"
        rel="stylesheet" />
    <!-- Material Symbols -->
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" />
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-secondary-fixed-variant": "#3d4c44",
                        "primary-container": "#d1fae5",
                        "tertiary": "#006953",
                        "on-background": "#1a1c1c",
                        "outline-variant": "#c4d6cc",
                        "surface-container": "#eeeeee",
                        "on-error-container": "#93000a",
                        "primary-fixed": "#d1fae5",
                        "on-primary-fixed-variant": "#065f46",
                        "tertiary-fixed-dim": "#2edfb5",
                        "error-container": "#ffdad6",
                        "primary-fixed-dim": "#a7f3d0",
                        "on-secondary-container": "#4d7f66",
                        "surface-dim": "#dadada",
                        "outline": "#75867c",
                        "on-primary-container": "#064e3b",
                        "secondary": "#54866e",
                        "surface-container-lowest": "#ffffff",
                        "on-primary": "#ffffff",
                        "secondary-fixed": "#dbffe9",
                        "tertiary-fixed": "#58fcd0",
                        "surface": "#f9f9f9",
                        "surface-container-highest": "#e2e2e2",
                        "inverse-primary": "#a7f3d0",
                        "error": "#ba1a1a",
                        "surface-bright": "#f9f9f9",
                        "on-tertiary-fixed-variant": "#00513f",
                        "on-error": "#ffffff",
                        "on-primary-fixed": "#064e3b",
                        "on-secondary-fixed": "#0f3e27",
                        "background": "#f9f9f9",
                        "on-secondary": "#ffffff",
                        "on-tertiary-container": "#f5fff9",
                        "on-tertiary-fixed": "#002118",
                        "surface-container-high": "#e8e8e8",
                        "surface-variant": "#e2e2e2",
                        "on-surface": "#1a1c1c",
                        "secondary-container": "#c3fde1",
                        "inverse-surface": "#2f3131",
                        "inverse-on-surface": "#f1f1f1",
                        "surface-tint": "#10b981",
                        "surface-container-low": "#f3f3f3",
                        "on-surface-variant": "#45544d",
                        "secondary-fixed-dim": "#bbf4d9",
                        "on-tertiary": "#ffffff",
                        "tertiary-container": "#008469",
                        "primary": "#10b981"
                    },
                    fontFamily: {
                        "headline": ["Plus Jakarta Sans", "Public Sans"],
                        "body": ["Public Sans"],
                        "label": ["Public Sans"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <script src="https://www.google.com/recaptcha/api.js"></script>
    <script>
        function onSubmit(token) {
            document.getElementById("filters").submit();
        }

        document.getElementById('filters').addEventListener('submit', function () {
            document.getElementById("submit-button").disabled = true;
            document.getElementById("submit-button").setAttribute("disabled", "disabled");
        });
    </script>
    <style>
        body {
            font-family: 'Public Sans', sans-serif;
            background-color: #F8F7FA;
        }

        .font-jakarta {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
    </style>
</head>

<body class="text-on-surface">
    <!-- TopNavBar (Simplified) -->
    <main class="pb-12 px-8 max-w-[1440px] mx-auto min-h-screen pt-12">
        <!-- Metadata Header -->
        <div
            class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 pb-6 border-b border-outline-variant/20 gap-4">
            <div class="flex items-center gap-4">
                <a href="/" class="flex items-center gap-4">
                    <img alt="Logo" class="h-12 w-12 object-contain" src="assets/parrot.png" />
                    <div class="flex flex-col gap-1">
                        <h1 class="text-3xl font-extrabold tracking-tight text-on-surface font-jakarta">Parrot</h1>
                        <p class="text-on-surface-variant/70 font-medium">Nightscout data stats</p>
                    </div>
                </a>
            </div>
        </div>


        {% if error is not null %}
        <!-- Error Message Card -->
        <div
            class="bg-surface-container-lowest p-8 rounded-xl shadow-[0_10px_30px_rgba(24,1,48,0.06)] mb-8 w-full border border-outline-variant/10">
            <div class="mb-4">
                <h3 class="text-xl font-bold text-on-surface">{{ error.title }}</h3>
            </div>
            <div class="flex flex-col items-center justify-center py-8 gap-4">
                <span class="material-symbols-outlined text-6xl text-primary/60">error</span>
                <p class="text-xl font-semibold text-on-surface-variant">{{ error.message }}</p>
            </div>
        </div>
        {% endif %}


        <!-- Filters Section -->
        <form action="" method="post" id="filters" name="filters">
            <div class="flex flex-col md:flex-row items-end gap-4 mb-10 w-full">
                <div class="w-full md:w-[60%]">
                    <label class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2"
                        for="nightscout_address">Nightscout Address</label>
                    <input name="nightscout_address"
                        class="w-full px-4 py-2.5 bg-surface-container-lowest border border-outline-variant/30 rounded-lg text-on-surface focus:outline-none focus:border-primary/50 transition-colors duration-200 placeholder:text-on-surface-variant/30"
                        id="nightscout_address" placeholder="https://example.com" type="text"
                        value="{{ filters.nightscout_address }}" />
                </div>
                <div class="w-full md:w-[10%]">
                    <label class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2"
                        for="min-glucose">Min. Glucose</label>
                    <input name="min_glucose"
                        class="w-full px-4 py-2.5 bg-surface-container-lowest border border-outline-variant/30 rounded-lg text-on-surface focus:outline-none focus:border-primary/50 transition-colors duration-200 placeholder:text-on-surface-variant/30"
                        id="min-glucose" placeholder="70" type="number" value="{{ filters.min_glucose }}" />
                </div>
                <div class="w-full md:w-[10%]">
                    <label class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2"
                        for="max-glucose">Max. Glucose</label>
                    <input name="max_glucose"
                        class="w-full px-4 py-2.5 bg-surface-container-lowest border border-outline-variant/30 rounded-lg text-on-surface focus:outline-none focus:border-primary/50 transition-colors duration-200 placeholder:text-on-surface-variant/30"
                        id="max-glucose" placeholder="180" type="number" value="{{ filters.max_glucose }}" />
                </div>
                <div class="w-full md:w-[10%]">
                    <label class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2"
                        for="days">Days</label>
                    <input name="days"
                        class="w-full px-4 py-2.5 bg-surface-container-lowest border border-outline-variant/30 rounded-lg text-on-surface focus:outline-none focus:border-primary/50 transition-colors duration-200 placeholder:text-on-surface-variant/30"
                        id="days" placeholder="14" type="number" value="{{ filters.days }}" />
                </div>
                <div class="w-full md:w-[10%]">
                    <button id="submit-button" type="button"
                        class="w-full h-[45.6px] flex items-center justify-center bg-primary text-on-primary rounded-lg hover:bg-primary/90 transition-colors duration-200 shadow-md disabled:bg-gray-400 disabled:cursor-not-allowed g-recaptcha"
                        data-sitekey="{{ recaptcha_key }}" data-callback='onSubmit' data-action='submit'>
                        <span class="material-symbols-outlined">search</span>
                    </button>
                </div>
            </div>
        </form>






        {% if stats is not null %}
        <!-- Risk Alerts Section -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">

            <!-- Card 6: Hyper Risk -->
            <div
                class="bg-surface-container-lowest p-8 rounded-xl shadow-[0_10px_30px_rgba(24,1,48,0.06)] border-l-4 border-primary/40">
                <div class="text-center">
                    <h3 class="text-lg font-bold text-on-surface mb-4">
                        TIR ({{ filters.min_glucose}}-{{filters.max_glucose}})</h3>
                    <div class="flex items-baseline gap-2 justify-center">
                        <span class="text-4xl font-black">{{ stats.glucose.stats.tir_percent}}</span>
                        <span class="text-xl font-medium text-on-surface-variant/50">%</span>
                    </div>
                </div>
            </div>

            <!-- Card 5: Hypo Risk -->
            <div
                class="bg-surface-container-lowest p-8 rounded-xl shadow-[0_10px_30px_rgba(24,1,48,0.06)] border-l-4 border-error/40">
                <div class="text-center">
                    <h3 class="text-lg font-bold text-on-surface mb-4">Mean Glucose</h3>
                    <div class="flex items-baseline gap-2 justify-center">
                        <span class="text-4xl font-black text-on-surface">{{ stats.glucose.stats.mean|round(0)}}</span>
                        <span class="text-xl font-medium text-on-surface-variant/50">mg/dL</span>
                    </div>
                </div>
            </div>

        </div>


        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">

            <!-- Card 2 -->
            <div class="bg-surface-container-lowest p-6 rounded-xl shadow-[0_10px_30px_rgba(24,1,48,0.06)]">
                <h3 class="text-sm font-semibold text-on-surface-variant mb-1">Coefficient of variation - CV</h3>
                <div class="flex items-baseline gap-2">
                    <span class="text-2xl font-bold text-on-surface">{{ stats.glucose.stats.cv}}</span>
                    <span class="text-sm text-on-surface-variant">%</span>
                </div>
            </div>
            <!-- Card 3 -->
            <div class="bg-surface-container-lowest p-6 rounded-xl shadow-[0_10px_30px_rgba(24,1,48,0.06)]">
                <h3 class="text-sm font-semibold text-on-surface-variant mb-1">Standard deviation - SD</h3>
                <div class="flex items-baseline gap-2">
                    <span class="text-2xl font-bold text-on-surface">{{ stats.glucose.stats.sd}}</span>
                </div>
            </div>


            <!-- Card 1 -->
            <div class="bg-surface-container-lowest p-6 rounded-xl shadow-[0_10px_30px_rgba(24,1,48,0.06)]">
                <h3 class="text-sm font-semibold text-on-surface-variant mb-1">Time Below Range – TBR (&lt;
                    {{ filters.min_glucose}})</h3>
                <div class="flex items-baseline gap-2">
                    <span class="text-2xl font-bold text-on-surface">{{
                        stats.glucose.stats.tbr_percent}}</span>
                    <span class="text-sm text-on-surface-variant">%</span>
                </div>
            </div>

            <!-- Card 4 -->
            <div class="bg-surface-container-lowest p-6 rounded-xl shadow-[0_10px_30px_rgba(24,1,48,0.06)]">
                <h3 class="text-sm font-semibold text-on-surface-variant mb-1">Time Above Range - TAR (&gt;
                    {{ filters.max_glucose}})</h3>
                <div class="flex items-baseline gap-2">
                    <span class="text-2xl font-bold">{{ stats.glucose.stats.tar_percent}}</span>
                    <span class="text-sm text-tertiary">%</span>
                </div>
            </div>
        </div>


        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">

            <!-- Card 2 -->
            <div class="bg-surface-container-lowest p-6 rounded-xl shadow-[0_10px_30px_rgba(24,1,48,0.06)]">
                <h3 class="text-sm font-semibold text-on-surface-variant mb-1">
                    Dawn - Mean [0h - 6h]
                </h3>
                <div class="flex items-baseline gap-2">
                    <span class="text-2xl font-bold text-on-surface">
                        {{stats.glucose.daily_periods.dawn.mean|round(0)}}
                    </span>
                    <span class="text-sm text-on-surface-variant">mg/dL</span>
                </div>
            </div>
            <!-- Card 3 -->
            <div class="bg-surface-container-lowest p-6 rounded-xl shadow-[0_10px_30px_rgba(24,1,48,0.06)]">
                <h3 class="text-sm font-semibold text-on-surface-variant mb-1">Morning - Mean [6h - 12h]</h3>
                <div class="flex items-baseline gap-2">
                    <span class="text-2xl font-bold text-on-surface">
                        {{stats.glucose.daily_periods.morning.mean|round(0)}}
                    </span>
                    <span class="text-sm text-on-surface-variant">mg/dL</span>
                </div>
            </div>


            <!-- Card 1 -->
            <div class="bg-surface-container-lowest p-6 rounded-xl shadow-[0_10px_30px_rgba(24,1,48,0.06)]">
                <h3 class="text-sm font-semibold text-on-surface-variant mb-1">Afternoon - Mean [12h - 18h]</h3>
                <div class="flex items-baseline gap-2">
                    <span class="text-2xl font-bold text-on-surface">
                        {{stats.glucose.daily_periods.afternoon.mean|round(0)}}
                    </span>
                    <span class="text-sm text-on-surface-variant">mg/dL</span>
                </div>
            </div>

            <!-- Card 4 -->
            <div class="bg-surface-container-lowest p-6 rounded-xl shadow-[0_10px_30px_rgba(24,1,48,0.06)]">
                <h3 class="text-sm font-semibold text-on-surface-variant mb-1">Night - Mean [18h - 24h]</h3>
                <div class="flex items-baseline gap-2">
                    <span class="text-2xl font-bold text-on-surface">
                        {{stats.glucose.daily_periods.night.mean|round(0)}}
                    </span>
                    <span class="text-sm text-on-surface-variant">mg/dL</span>
                </div>
            </div>
        </div>

        <!-- Detailed Data Table Section -->

        <div class="bg-surface-container-lowest rounded-xl shadow-[0_10px_30px_rgba(24,1,48,0.06)] overflow-hidden">
            <div class="px-8 py-6 border-b border-outline-variant/10">
                <h2 class="text-xl font-bold text-on-surface">Ambulatory Glucose Profile - AGP</h2>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse table-auto">
                    <thead>
                        <tr class="bg-surface-container-low/50">
                            <th
                                class="px-8 py-4 text-xs font-bold text-on-surface-variant/60 uppercase tracking-widest">
                                Hour
                            </th>
                            <th
                                class="px-8 py-4 text-xs font-bold text-on-surface-variant/60 uppercase tracking-widest">
                                Mean (mg/dL)
                            </th>
                            <th
                                class="px-8 py-4 text-xs font-bold text-on-surface-variant/60 uppercase tracking-widest">
                                P25
                            </th>
                            <th
                                class="px-8 py-4 text-xs font-bold text-on-surface-variant/60 uppercase tracking-widest">
                                P50 (Median)
                            </th>
                            <th
                                class="px-8 py-4 text-xs font-bold text-on-surface-variant/60 uppercase tracking-widest">
                                P75
                            </th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant/5">
                        {% for hour, values in stats.glucose.agp %}
                        <tr
                            class="{{ loop.index is even ? 'bg-surface-container-low/30' : 'bg-surface-container-lowest' }}">
                            <td class="px-8 py-4 font-semibold text-on-surface">{{ "%02d:00"|format(hour) }}</td>
                            <td class="px-8 py-4 text-on-surface-variant">{{ values.mean|round(0) }}</td>
                            <td class="px-8 py-4 text-on-surface-variant">{{ values.p25|round(0) }}</td>
                            <td class="px-8 py-4 text-on-surface-variant">{{ values.p50|round(0) }}</td>
                            <td class="px-8 py-4 text-on-surface-variant">{{ values.p75|round(0) }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="p-6 text-center">
                <p class="text-on-surface-variant text-sm font-medium">
                    {{ stats.glucose.values|length }} entries from {{ stats.start }} to {{ stats.end }}
                </p>
            </div>
        </div>
        {% endif %}

    </main>
    <footer class="w-full py-6 mt-auto bg-[#f9f9f9] border-t border-[#c8c4d6]/15">
        <div class="flex flex-col md:flex-row justify-between items-center px-8 w-full max-w-[1440px] mx-auto gap-4">
            <span class="font-public-sans text-xs text-gray-400">Parrot - Nightscout data stats</span>
            <div class="flex gap-6">
                <!-- <span class="text-gray-400 text-xs">Documentation</span>
                <span class="text-gray-400 text-xs">Privacy</span>
                <span class="text-gray-400 text-xs">Help Center</span> -->
            </div>
        </div>
    </footer>
</body>

</html>